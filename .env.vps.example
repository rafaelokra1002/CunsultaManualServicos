# =====================================================
# Configuração da VPS (Backend + Banco de Dados)
# Copie este arquivo para .env no servidor da VPS
# =====================================================

# PostgreSQL local na VPS
DATABASE_URL="postgresql://oficina_user:SUA_SENHA_FORTE@localhost:5432/oficina_digital"
DIRECT_URL="postgresql://oficina_user:SUA_SENHA_FORTE@localhost:5432/oficina_digital"

# NextAuth - Use a MESMA secret que está na Vercel
NEXTAUTH_SECRET="mesma-secret-da-vercel"

# NEXTAUTH_URL deve apontar para o domínio da Vercel (frontend público)
NEXTAUTH_URL="https://seu-dominio-vercel.vercel.app"

# Porta do servidor Next.js na VPS (atrás do Nginx)
PORT=3001

# Mistic Pay - API de Pagamento PIX
MISTICPAY_CLIENT_ID="seu_client_id"
MISTICPAY_CLIENT_SECRET="seu_client_secret"
