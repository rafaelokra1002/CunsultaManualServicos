generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String    @id @default(cuid())
  nome      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  active    Boolean   @default(false)
  createdAt DateTime  @default(now())
  payments  Payment[]

  @@map("users")
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  amount          Float
  status          String   @default("pending") // pending, approved, expired
  pushinPayId     String?  @unique
  pixCode         String?
  pixQrCode       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("payments")
}

model Manual {
  id        String   @id @default(cuid())
  title     String
  brand     String
  model     String
  year      Int
  fileUrl   String
  coverUrl  String?
  category  String   @default("servico") // "servico" ou "catalogo"
  createdAt DateTime @default(now())

  @@map("manuals")
}
